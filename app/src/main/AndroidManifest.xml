<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".TennisApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartformTennis"
        tools:targetApi="34">

        <!-- 主界面 -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 欢迎页 -->
        <activity
            android:name=".ui.WelcomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- 权限说明页 -->
        <activity
            android:name=".ui.PermissionActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- 个人信息录入页 -->
        <activity
            android:name=".ui.ProfileSetupActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- 设备绑定页 -->
        <activity
            android:name=".ui.DeviceBindActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- 新手引导页 -->
        <activity
            android:name=".ui.GuideActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- 训练报告页面 -->
        <activity
            android:name=".ui.ReportActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

    </application>

</manifest>
