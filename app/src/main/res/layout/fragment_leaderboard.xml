<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ranking_title"
        android:textSize="@dimen/text_title"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:padding="@dimen/margin_normal"/>

    <!-- Tab 切换 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_normal"
        android:layout_marginBottom="@dimen/margin_normal">

        <TextView
            android:id="@+id/tabShots"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ranking_tab_shots"
            android:textSize="@dimen/text_normal"
            android:textColor="@color/brand_primary"
            android:gravity="center"
            android:paddingVertical="@dimen/margin_small"
            android:background="@drawable/bg_tab_selected"/>

        <TextView
            android:id="@+id/tabDuration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ranking_tab_duration"
            android:textSize="@dimen/text_normal"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingVertical="@dimen/margin_small"
            android:layout_marginStart="@dimen/margin_small"/>

        <TextView
            android:id="@+id/tabTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ranking_tab_total"
            android:textSize="@dimen/text_normal"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingVertical="@dimen/margin_small"
            android:layout_marginStart="@dimen/margin_small"/>
    </LinearLayout>

    <!-- 排行榜列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rankingRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/margin_normal"
        android:clipToPadding="false"/>

    <!-- 我的排名（固定在底部，排名 > 10 时显示） -->
    <LinearLayout
        android:id="@+id/myRankFixedContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_secondary"
            android:alpha="0.3"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/margin_normal"
            android:gravity="center_vertical"
            android:background="#1A8BC34A">

            <!-- 排名 -->
            <TextView
                android:id="@+id/myFixedRank"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="15"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"/>

            <!-- 头像 -->
            <TextView
                android:id="@+id/myFixedAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🧑"
                android:textSize="20dp"
                android:layout_marginStart="@dimen/margin_small"/>

            <!-- 昵称 -->
            <TextView
                android:id="@+id/myFixedNickname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/margin_normal"
                android:text="我"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"/>

            <!-- 击球数 -->
            <TextView
                android:id="@+id/myFixedScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 次"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"/>

            <!-- 差距提示 -->
            <TextView
                android:id="@+id/myFixedGapText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_normal"
                android:text="距第3名还差 0 球"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_secondary"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
