<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="@dimen/margin_normal">

    <!-- 顶部：连接状态 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/connectionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/corner_normal"
        app:cardElevation="@dimen/card_elevation"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/margin_normal"
            android:gravity="center_vertical">

            <!-- 蓝牙图标 -->
            <ImageView
                android:id="@+id/bluetoothIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_bluetooth"
                android:contentDescription="蓝牙状态"/>

            <!-- 状态文字 -->
            <TextView
                android:id="@+id/connectionStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/margin_normal"
                android:text="@string/home_connect_device"
                android:textSize="@dimen/text_medium"
                android:textColor="@color/text_secondary"/>

            <!-- 连接按钮 -->
            <Button
                android:id="@+id/connectButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接设备"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 中部：实时统计数据 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/statsCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_normal"
        app:cardCornerRadius="@dimen/corner_normal"
        app:cardElevation="@dimen/card_elevation"
        app:layout_constraintTop_toBottomOf="@id/connectionCard"
        app:layout_constraintBottom_toTopOf="@id/actionButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/margin_normal">

                <!-- 总击球数 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/home_total_shots"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/totalShotsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="@dimen/text_xlarge"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- 最大速度 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/home_max_speed"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/maxSpeedText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 km/h"
                        android:textSize="@dimen/text_xlarge"
                        android:textStyle="bold"
                        android:textColor="@color/accent"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/text_hint"
                    android:layout_marginVertical="@dimen/margin_small"/>

                <!-- 正手击球 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/shot_forehand"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/shot_forehand"
                        android:textSize="@dimen/text_normal"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/forehandText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- 反手击球 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/shot_backhand"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/shot_backhand"
                        android:textSize="@dimen/text_normal"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/backhandText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- 切削 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/shot_slice"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/shot_slice"
                        android:textSize="@dimen/text_normal"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/sliceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- 高压/发球 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/shot_serve"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/shot_serve"
                        android:textSize="@dimen/text_normal"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/serveText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- 正手截击 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/shot_forehand_volley"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/shot_forehand_volley"
                        android:textSize="@dimen/text_normal"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/forehandVolleyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- 反手截击 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="@dimen/margin_small">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/shot_backhand_volley"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/shot_backhand_volley"
                        android:textSize="@dimen/text_normal"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/backhandVolleyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- 底部：操作按钮 -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="@dimen/margin_large"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/startTrainingButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_normal"
            android:text="@string/home_start_training"
            android:textSize="@dimen/text_medium"
            android:background="@drawable/bg_button_primary"/>

        <Button
            android:id="@+id/stopTrainingButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/home_stop_training"
            android:textSize="@dimen/text_medium"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.OutlinedButton"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
