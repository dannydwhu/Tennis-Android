<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/corner_card"
    app:cardBackgroundColor="@color/bg_card"
    android:layout_marginBottom="@dimen/margin_small">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/margin_normal"
        android:gravity="center_vertical">

        <!-- 排名 -->
        <TextView
            android:id="@+id/rankText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="1"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:textColor="@color/brand_primary"
            android:gravity="center"/>

        <!-- 头像 -->
        <ImageView
            android:id="@+id/avatarImage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_default_avatar"
            android:contentDescription="头像"
            android:layout_marginStart="@dimen/margin_small"/>

        <!-- 用户信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/margin_normal">

            <TextView
                android:id="@+id/nicknameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户名"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/statsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,234 次"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- 排名变化 -->
        <ImageView
            android:id="@+id/rankChangeIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_rank_up"
            android:contentDescription="排名变化"
            android:tint="@color/brand_primary"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
