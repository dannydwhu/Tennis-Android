<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- 顶部栏：正在训练 + 计时器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/bg_dark">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/ic_dot"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在训练"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/brand_primary"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 速度仪表盘区域 - 缩小版 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_card"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最大速度"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp"/>

                <!-- 进度条 -->
                <ProgressBar
                    android:id="@+id/maxSpeedProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="200"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"
                    android:layout_marginBottom="12dp"/>

                <!-- 速度数字 - 缩小 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/maxSpeedValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km/h"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 总击球数 - 缩小版 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总击球数"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/totalShotsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- 击球类型列表 - 紧凑版 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="击球统计"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>

                <!-- 正手 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/ic_dot"
                        android:backgroundTint="@color/shot_forehand"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="正手"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/forehandCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/shot_forehand"
                        android:minWidth="36dp"
                        android:gravity="end"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/forehandProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"/>

                <!-- 反手 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:layout_marginTop="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/ic_dot"
                        android:backgroundTint="@color/shot_backhand"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="反手"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/backhandCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/shot_backhand"
                        android:minWidth="36dp"
                        android:gravity="end"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/backhandProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"/>

                <!-- 切削 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:layout_marginTop="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/ic_dot"
                        android:backgroundTint="@color/shot_slice"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="切削"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/sliceCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/shot_slice"
                        android:minWidth="36dp"
                        android:gravity="end"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/sliceProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"/>

                <!-- 高压 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:layout_marginTop="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/ic_dot"
                        android:backgroundTint="@color/shot_serve"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="高压"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/serveCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/shot_serve"
                        android:minWidth="36dp"
                        android:gravity="end"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/serveProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"/>

                <!-- 正手截击 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:layout_marginTop="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/ic_dot"
                        android:backgroundTint="@color/shot_forehand_volley"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="正手截击"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/forehandVolleyCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/shot_forehand_volley"
                        android:minWidth="36dp"
                        android:gravity="end"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/forehandVolleyProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"/>

                <!-- 反手截击 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:layout_marginTop="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/ic_dot"
                        android:backgroundTint="@color/shot_backhand_volley"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="反手截击"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/backhandVolleyCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/shot_backhand_volley"
                        android:minWidth="36dp"
                        android:gravity="end"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/backhandVolleyProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"/>

            </LinearLayout>

            <!-- 传感器数据日志 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="传感器模拟数据"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:background="#000000"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/sensorDataLogText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="等待训练数据..."
                        android:textSize="9sp"
                        android:textColor="#00FF00"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="2dp"/>
                </ScrollView>
            </LinearLayout>

            <!-- 停止训练按钮 -->
            <Button
                android:id="@+id/stopTrainingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="停止训练"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/bg_button_danger"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
